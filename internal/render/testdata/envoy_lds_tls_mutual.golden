resources:
  - "@type": type.googleapis.com/envoy.config.listener.v3.Listener
    name: listener_grpc_mtls
    address:
      socket_address:
        address: 0.0.0.0
        port_value: 9443
    filter_chains:
      - filters:
          - name: envoy.filters.network.tcp_proxy
            typed_config:
              "@type": type.googleapis.com/envoy.extensions.filters.network.tcp_proxy.v3.TcpProxy
              stat_prefix: tcp_grpc_mtls
              cluster: cluster_grpc_mtls
        transport_socket:
          name: envoy.transport_sockets.tls
          typed_config:
            "@type": type.googleapis.com/envoy.extensions.transport_sockets.tls.v3.DownstreamTlsContext
            require_client_certificate: true
            common_tls_context:
              tls_certificate_sds_secret_configs:
                - name: grpc_mtls
                  sds_config:
                    path_config_source:
                      path: /etc/envoy/tls/grpc_mtls.sds.yaml
                      watched_directory:
                        path: /etc/envoy/tls
              validation_context_sds_secret_config:
                name: grpc_mtls-ca
                sds_config:
                  path_config_source:
                    path: /etc/envoy/tls/grpc_mtls.sds.yaml
                    watched_directory:
                      path: /etc/envoy/tls
